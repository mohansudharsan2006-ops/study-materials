# PostgreSQL Database Configuration
# Copy this file to .env and update with your actual database credentials

# Option 1: Using DATABASE_URL (for cloud deployments like Heroku, Railway, Render)
# DATABASE_URL=postgresql://username:password@host:5432/dbname

# Option 2: Using individual connection parameters (for local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=study_materials
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=advanced_secret_key_2024

# File Upload Configuration
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800  # 50MB in bytes
